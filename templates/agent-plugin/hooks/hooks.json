{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "SendMessage",
        "hook": {
          "type": "command",
          "command": "bash hooks/intercept-send-message.sh"
        }
      }
    ],
    "Stop": [
      {
        "hook": {
          "type": "command",
          "command": "bash hooks/require-submit.sh"
        }
      }
    ]
  }
}
